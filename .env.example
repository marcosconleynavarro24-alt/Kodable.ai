# ── Kodable.ai environment ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# Everything below is OPTIONAL: with nothing set, the site still works — leads
# are validated, stored to data/leads.ndjson, and the emails that *would* be
# sent are written to data/outbox/ so you can preview them. Set the email vars
# to turn on real delivery.

# ── Email delivery (Resend — https://resend.com) ───────────────────────────
# 1. Create a free Resend account and an API key.
# 2. Verify the kodable.ai domain in Resend (or, for testing, leave the domain
#    and send from onboarding@resend.dev to your own verified address).
# 3. Paste the key and your inbox below. Leads then arrive in your inbox and the
#    customer gets a friendly auto-reply.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=you@example.com
LEAD_FROM_EMAIL=Kodable.ai <hola@kodable.ai>

# Booking notifications (when someone books a meeting via the widget) go to this
# comma-separated list. Falls back to LEAD_NOTIFY_EMAIL if unset.
BOOKING_NOTIFY_EMAIL=you@example.com, you@kodable.ai

# ── Admin leads export ─────────────────────────────────────────────────────
# A secret token to read stored leads at /api/leads?token=...  (and ?format=csv).
# Generate one with:  openssl rand -hex 24
ADMIN_TOKEN=
